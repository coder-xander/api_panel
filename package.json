{
  "name": "api-panel",
  "version": "0.3.3",
  "description": "AI API Panel — Multi-platform balance & usage tracker (Electron)",
  "author": "Hermes <hermes@localhost>",
  "homepage": "https://github.com/hermes/api-panel",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron . --no-sandbox --disable-setuid-sandbox --enable-transparent-visuals",
    "build": "electron-builder",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --linux --win",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "reinstall": "node -e \"if(process.platform==='win32'){console.log('Please run npm run build:win first')}else{const{execSync}=require('child_process');execSync('rm -f dist/*.deb && npm run build:linux',{stdio:'inherit'});console.log('Build complete. Install with: sudo dpkg -i dist/api-panel_*.deb')}\""
  },
  "build": {
    "appId": "com.hermes.api-panel",
    "productName": "API Panel",
    "copyright": "Copyright © 2026 Hermes",
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "executableName": "api-panel",
      "icon": "build/icons",
      "executableArgs": [
        "--no-sandbox",
        "--disable-setuid-sandbox",
        "--enable-transparent-visuals"
      ]
    },
    "win": {
      "target": "nsis",
      "icon": "build/icons/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icons/icon.ico",
      "uninstallerIcon": "build/icons/icon.ico"
    },
    "files": [
      "electron/**",
      "src/**"
    ],
    "extraResources": []
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "@vue/test-utils": "^2.4.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "happy-dom": "^15.11.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "gridstack": "^12.6.0",
    "ws": "^8.21.0"
  }
}
